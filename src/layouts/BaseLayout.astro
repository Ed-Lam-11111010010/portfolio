---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = "Edwin Lam — Portfolio", description = "Portfolio of Lam Chi (Edwin) — Information Engineering student, game designer, and creative technologist." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0071e3" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- AOS Animation Library -->
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <!-- BoxIcons -->
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
  </head>
  <body>
    <header class="header">
      <div class="container">
        <a href="/" class="logo">Edwin <span>Lam</span></a>
        <div class="bx bx-menu" id="menu-icon"></div>
        <nav class="navbar">
          <a href="#home" class="active">Home</a>
          <a href="#about">About</a>
          <a href="#skills">Skills</a>
          <a href="#projects">Projects</a>
          <a href="#contact">Contact</a>
          <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
            <span id="themeIcon">🌙</span>
          </button>
          <span class="active-nav"></span>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <p class="footer-text">&copy; {new Date().getFullYear()} Edwin Lam (Lam Chi). Built with Astro.</p>
        <div class="footer-iconTop">
          <a href="#home"><i class="bx bx-up-arrow-alt"></i></a>
        </div>
        <div class="footer-links">
          <a href="https://github.com/Ed-Lam-11111010010" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="mailto:edwin.lam@example.com">Email</a>
        </div>
      </div>
    </footer>

    <!-- AOS -->
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <!-- Typed.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/typed.js/2.1.0/typed.umd.js"></script>
    <script>
      // Hamburger menu toggle
      const menuIcon = document.getElementById('menu-icon');
      const navbar = document.querySelector('.navbar');
      if (menuIcon && navbar) {
        menuIcon.addEventListener('click', () => {
          menuIcon.classList.toggle('bx-x');
          navbar.classList.toggle('active');
        });
      }
      
      // Close nav on link click
      document.querySelectorAll('.navbar a').forEach(link => {
        link.addEventListener('click', () => {
          menuIcon?.classList.remove('bx-x');
          navbar?.classList.remove('active');
        });
      });
      
      // AOS initialization
      if (typeof AOS !== 'undefined') {
        AOS.init({
          duration: 1000,
          once: true,
          offset: 100,
          easing: 'ease-in-out'
        });
      }

      // Theme toggle
      const themeToggle = document.getElementById('themeToggle');
      const themeIcon = document.getElementById('themeIcon');

      function getTheme() {
        return localStorage.getItem('theme') || 'light';
      }

      function setTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        themeIcon.textContent = theme === 'dark' ? '☀️' : '🌙';
      }

      // Initialize theme
      setTheme(getTheme());

      themeToggle.addEventListener('click', () => {
        const current = getTheme();
        setTheme(current === 'dark' ? 'light' : 'dark');
      });

      // Register service worker for PWA
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {
            // Service worker registration failed silently
          });
        });
      }
    </script>
  </body>
</html>
