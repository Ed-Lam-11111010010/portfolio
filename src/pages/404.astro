---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <div class="not-found">
    <div class="container">
      <h1>404</h1>
      <p>The page you're looking for doesn't exist.</p>
      <a href="/" class="detail-links">
        <span class="btn">Back to home</span>
      </a>
    </div>
  </div>
</BaseLayout>
