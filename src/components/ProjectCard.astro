---
import { findGenreForSkill, getSkillSlug } from '../data/skills.js';
const base = import.meta.env.BASE_URL;

interface Props {
  project: {
    id: string;
    title: string;
    description: string;
    year: number;
    category: string;
    skills: string[];
    image: string | null;
    links: {
      github: string | null;
      demo: string | null;
      video: string | null;
    };
    highlights: string[];
    external?: boolean;
    source_url?: string | null;
    type?: string;
  };
}

const { project } = Astro.props;
const skillList = project.skills.join(',');
const cardClass = project.external ? 'project-card project-card--external' : 'project-card';
---

<article class={cardClass} data-project-skills={skillList}>
  <a href={`${base}projects/${project.id}`} class="project-card-link">
    <div class="project-card-image">
      {project.image ? (
        <img src={project.image} alt={project.title} loading="lazy" />
      ) : (
        <span>📁</span>
      )}
    </div>
    <div class="project-card-body">
      <h3 class="project-card-title">
        {project.title}
        {project.external && <span class="badge-external">Cloud</span>}
      </h3>
      <p class="project-card-year">
        {project.type && <span class="project-type-badge">{project.type}</span>}
        <span>{project.year}</span>
      </p>
      <p class="project-card-desc">{project.description}</p>
      <div class="project-card-skills">
        {project.skills.slice(0, 4).map((skill) => {
          const info = findGenreForSkill(skill);
          return (
            <a
              href={`${base}skills/${info.genreSlug}/${getSkillSlug(skill)}`}
              class="project-card-skill"
              data-skill={skill}
            >{skill}</a>
          );
        })}
        {project.skills.length > 4 && (
          <span class="project-card-skill">+{project.skills.length - 4}</span>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .project-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
</style>
