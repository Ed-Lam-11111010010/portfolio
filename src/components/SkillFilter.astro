---
import { getGenres, findGenreForSkill, getSkillSlug } from '../data/skills.js';
const base = import.meta.env.BASE_URL;

const genres = getGenres();
const allGenres = [{ name: 'All', slug: 'all' }, ...genres];
---

<div class="skill-filter" id="skillFilter">
  <div class="genre-tabs" id="genreTabs">
    {allGenres.map((g) => (
      <button class="genre-tab" data-genre={g.slug} type="button">{g.name}</button>
    ))}
  </div>
  <div class="type-tabs">
    <button class="type-tab active" data-type="" type="button">All Types</button>
    <button class="type-tab" data-type="personal" type="button">Personal</button>
    <button class="type-tab" data-type="coursework" type="button">Coursework</button>
    <button class="type-tab" data-type="game-dev" type="button">Game Dev</button>
    <button class="type-tab" data-type="game-design" type="button">Game Design</button>
    <button class="type-tab" data-type="multimedia" type="button">Multimedia</button>
    <button class="type-tab" data-type="leadership" type="button">Leadership</button>
    <button class="type-tab" data-type="documentation" type="button">Documentation</button>
  </div>
  <div class="skill-chips" id="skillChips">
    {genres.map((genre) => (
      <div class="skill-slider-wrapper" data-genre={genre.slug} style="display: none;">
        <button class="scroll-btn scroll-btn--left" data-scroll-genre={genre.slug} type="button" aria-label="Scroll left">‹</button>
        <div class="skill-chip-group" data-genre={genre.slug}>
          {genre.skills.map((skill) => (
            <a
              href={`${base}skills/${genre.slug}/${skill.slug}`}
              class="filter-tag"
              data-skill={skill.slug}
              data-genre={genre.slug}
            >{skill.name}</a>
          ))}
        </div>
        <button class="scroll-btn scroll-btn--right" data-scroll-genre={genre.slug} type="button" aria-label="Scroll right">›</button>
      </div>
    ))}
  </div>
  <button class="filter-clear" id="filterClear" type="button">Clear all</button>
</div>

<script>
  const genreTabs = document.querySelectorAll('.genre-tab');
  const filterTags = document.querySelectorAll('.filter-tag');
  const filterClear = document.getElementById('filterClear');
  const filterEmpty = document.getElementById('filterEmpty');
  const projectCards = () => document.querySelectorAll('.project-card');

  let activeGenre = 'all';
  let activeFilters = new Set();
  let activeType = "";

  // Apply active class to genre tab
  function updateGenreTabs() {
    genreTabs.forEach((tab) => {
      tab.classList.toggle('active', tab.dataset.genre === activeGenre);
    });
  }

  // Show/hide skill chip groups based on active genre
  function updateTypeTabs() {
    document.querySelectorAll(".type-tab").forEach((tab) => {
      tab.classList.toggle("active", tab.dataset.type === activeType);
    });
  }

  function updateChips() {
    document.querySelectorAll('.skill-slider-wrapper').forEach((wrapper) => {
      wrapper.style.display = activeGenre === 'all' || wrapper.dataset.genre === activeGenre ? '' : 'none';
    });
  }

  // Filter projects
    function updateFilter() {
    const cards = projectCards();
    let visibleCount = 0;

    if (activeFilters.size === 0 && !activeType) {
      cards.forEach((card) => { card.style.display = ""; });
      visibleCount = cards.length;
    } else {
      cards.forEach((card) => {
        const skills = (card.dataset.projectSkills || "").split(",");
        const matchesType = !activeType || card.dataset.projectType === activeType;
        const matchesSkills = activeFilters.size === 0 || [...activeFilters].every((filter) => skills.includes(filter));
        const matches = matchesType && matchesSkills;
        card.style.display = matches ? "" : "none";
        if (matches) visibleCount++;
      });
    }

    // Update active tag styles
    filterTags.forEach((tag) => {
      tag.classList.toggle("active", activeFilters.has(tag.dataset.skill));
    });

    // Show empty state
    if (filterEmpty) {
      filterEmpty.style.display = visibleCount === 0 ? "" : "none";
    }
  }

  // Genre tab click handler
  genreTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const genre = tab.dataset.genre;
      if (activeGenre === genre && genre !== 'all') {
        // Toggle off genre filter (show all)
        activeGenre = 'all';
      } else {
        activeGenre = genre;
      }
      activeFilters.clear();
      updateGenreTabs();
      updateChips();
      updateFilter();
    });
  });

  // Skill tag click handler (links navigate, but we also filter on click)
  filterTags.forEach((tag) => {
    tag.addEventListener('click', (e) => {
      e.preventDefault();
      const skill = tag.dataset.skill;
      if (activeFilters.has(skill)) {
        activeFilters.delete(skill);
      } else {
        activeFilters.add(skill);
      }
      updateFilter();
    });
  });

  // Scroll buttons for skill chip groups
  document.querySelectorAll('.scroll-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const genre = btn.dataset.scrollGenre;
      const group = document.querySelector(`.skill-chip-group[data-genre="${genre}"]`);
      if (!group) return;
      const scrollAmount = 200;
      if (btn.classList.contains('scroll-btn--left')) {
        group.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      } else {
        group.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      }
    });
  });

  filterClear?.addEventListener('click', () => {
    activeFilters.clear();
    activeGenre = 'all';
    updateGenreTabs();
    updateChips();
    updateFilter();
  });

  // Initialize
  updateGenreTabs();
  updateChips();
</script>

<style>
  .genre-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .genre-tab {
    background: var(--color-tag-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    padding: 0.45rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .genre-tab:hover {
    opacity: 0.85;
  }

  .genre-tab.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  .skill-slider-wrapper {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .skill-chip-group {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    padding: 0.5rem 0;
    flex: 1;
  }
  .skill-chip-group::-webkit-scrollbar {
    height: 4px;
  }
  .skill-chip-group::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 2px;
  }
  .scroll-btn {
    background: var(--color-tag-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  .scroll-btn:hover {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  .filter-tag {
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    border: none;
    padding: 0.4rem 0.9rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    text-decoration: none;
  }

  .filter-tag:hover {
    opacity: 0.8;
  }

  .filter-tag.active {
    background: var(--color-tag-active-bg);
    color: var(--color-tag-active-text);
  }

  .filter-clear {
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    padding: 0.4rem 0.9rem;
    border-radius: 20px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 0.25rem;
  }

  .filter-clear:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
.type-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .type-tab {
    background: var(--color-tag-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    padding: 0.45rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .type-tab:hover {
    opacity: 0.85;
  }
  .type-tab.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
</style>
